#!/usr/bin/env sh
set -eu

repo_dir=$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd)
install_root=${WAYTRIM_INSTALL_ROOT:-$HOME/.local}
user_systemd_dir=${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user

echo "Installing waytrim binaries to $install_root"
cargo install --path "$repo_dir" --force --root "$install_root"

mkdir -p "$user_systemd_dir"
install -Dm644 "$repo_dir/contrib/systemd/user/waytrim-watch.service" \
  "$user_systemd_dir/waytrim-watch.service"
install -Dm644 "$repo_dir/contrib/systemd/user/waytrim-watch@.service" \
  "$user_systemd_dir/waytrim-watch@.service"

if command -v systemctl >/dev/null 2>&1; then
  systemctl --user daemon-reload

  for unit in waytrim-watch.service waytrim-watch@auto.service; do
    if systemctl --user --quiet is-enabled "$unit" \
      || systemctl --user --quiet is-active "$unit"; then
      echo "Restarting $unit"
      systemctl --user restart "$unit"
    fi
  done
fi

echo "Done"
